# ─────────────────────────────────────────────────────────────────────────────
# PointCloud Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloudflare R2 (object storage — zero egress fees) ─────────────────────────
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=pointcloud-platform-data
# Public base URL for objects — either a custom domain or the r2.dev subdomain
# Example: https://assets.yourdomain.com  or  https://pub-HASH.r2.dev
R2_PUBLIC_BASE=https://pub-HASH.r2.dev

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_STARTER_PRICE_ID=price_starter_xxx
STRIPE_PRO_PRICE_ID=price_pro_yyy
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_zzz

# ── n8n Workflow Automation ──────────────────────────────────────────────────
N8N_API_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
# Webhook URLs — copy from your n8n workflow trigger nodes
N8N_PAYMENT_FAILED_WEBHOOK=https://your-n8n.up.railway.app/webhook/payment-failed
N8N_NEW_USER_WEBHOOK=https://your-n8n.up.railway.app/webhook/new-user-onboarding

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the FastAPI backend (used by Next.js at runtime)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Cesium Ion token — get one free at https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=your-cesium-ion-token
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# ── App ───────────────────────────────────────────────────────────────────────
APP_DOMAIN=https://app.yourdomain.com
# Comma-separated list of additional allowed CORS origins (optional)
# e.g. "https://staging.yourdomain.com,https://preview.yourdomain.com"
ALLOWED_ORIGINS=
API_SECRET_KEY=generate-a-long-random-string-here
ENVIRONMENT=development
