# ─────────────────────────────────────────────────────────────────────────────
# PointCloud Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=pointcloud-platform-data-ACCOUNT_ID
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/pointcloud-processing

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PROFESSIONAL_PRICE_ID=price_xxx
STRIPE_BUSINESS_PRICE_ID=price_yyy

# ── n8n Workflow Automation ──────────────────────────────────────────────────
N8N_API_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ── Argo Workflows ────────────────────────────────────────────────────────────
ARGO_SERVER_URL=https://argo.your-cluster.internal
ARGO_TOKEN=your-argo-token
ARGO_NAMESPACE=processing

# ── App ───────────────────────────────────────────────────────────────────────
APP_DOMAIN=https://app.yourdomain.com
API_SECRET_KEY=generate-a-long-random-string-here
ENVIRONMENT=development
